{
  "name": "factura",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "email": "email dev --dir emails --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenv -e .env.local drizzle-kit push",
    "db:seed": "dotenv -e .env.local tsx src/db/seed.ts",
    "db:studio": "dotenv -e .env.local drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdftotext": "^1.3.6",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/ui": "^6.6.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "react-email": "^6.6.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
