# Copy to .env.local

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://factura:factura@localhost:5433/factura

# ── Auth (NextAuth v5 / Auth.js) ────────────────────────────────────────────
# Generate a secret with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=factura.app
# Google OAuth credentials (console.cloud.google.com → Credentials → OAuth client).
# Authorized redirect URI: http://localhost:4000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Only needed if the app isn't served from its own origin (e.g. behind a proxy).
# AUTH_URL=http://localhost:4000

# ── Transactional email (Resend) ────────────────────────────────────────────
# Powers the email one-time-password sign-in plus welcome/invite mail.
# Leave RESEND_API_KEY blank in local dev: sign-in codes are logged to the
# server console instead of emailed, so you can still log in without Resend.
RESEND_API_KEY=
# Verified sender, e.g. "Factura <hello@yourdomain.com>".
EMAIL_FROM=

# ── S3-compatible storage for original PDFs ─────────────────────────────────
# Local dev points at the MinIO container in docker-compose. In production set
# these to Cloudflare R2 / AWS S3 / Backblaze — the code is identical.
# Leave blank to run text-only (no PDF upload / View PDF).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=factura
S3_ACCESS_KEY_ID=factura
S3_SECRET_ACCESS_KEY=facturasecret
# true for MinIO and most non-AWS providers; false (or unset) for AWS S3.
S3_FORCE_PATH_STYLE=true
